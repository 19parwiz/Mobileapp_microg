# Server Configuration
server.port=8080
spring.application.name=microgreens-backend

# Database Configuration - PostgreSQL
# IMPORTANT: Replace with your actual database credentials
spring.datasource.url=jdbc:postgresql://localhost:5432/microgreens_db
spring.datasource.username=postgresql
spring.datasource.password=54321
spring.datasource.driver-class-name=org.postgresql.Driver

# JPA/Hibernate Configuration
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.properties.hibernate.format_sql=true

# Logging
logging.level.root=INFO
logging.level.com.aliparwiz.microgreens=DEBUG
logging.level.org.springframework.web=DEBUG
logging.level.org.springframework.security=DEBUG
logging.level.org.hibernate.SQL=DEBUG

# JWT Configuration
# IMPORTANT: Generate a secure random key (at least 64 characters for HS512)
# You can generate one using: openssl rand -base64 64
jwt.secret=your-secret-key-here-minimum-64-characters-long-for-hs512-algorithm
jwt.expiration=86400000

# AI Service Configuration
# IMPORTANT: Replace with your actual AI service URL and API key
ai.service.url=http://localhost:5000
ai.service.api-key=your-api-key-here

# Application Info
app.name=Microgreens Management System
app.version=1.0.0
app.description=Spring Boot backend for microgreens management with IoT and AI integration


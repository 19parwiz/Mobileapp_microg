# Defaults live in application.properties (tracked). Copy this file to application-local.properties for machine-only overrides.

# Cloud hosts inject PORT; keep default 8080 for local Maven runs.
server.port=${PORT:8080}
spring.application.name=microgreens-backend

# Prefer env vars so you never commit passwords:
#   DATABASE_URL=jdbc:postgresql://localhost:5432/smart_microgreens_db
#   DATABASE_USERNAME=postgres
#   DATABASE_PASSWORD=<your PostgreSQL role password; default in application.properties is postgres>
# Docker Compose (microgreens_db / postgres): set DATABASE_URL=jdbc:postgresql://localhost:5432/microgreens_db and DATABASE_PASSWORD=postgres
spring.datasource.url=${SPRING_DATASOURCE_URL:${DATABASE_URL:jdbc:postgresql://localhost:5432/smart_microgreens_db}}
spring.datasource.username=${DATABASE_USERNAME:postgres}
spring.datasource.password=${DATABASE_PASSWORD:postgres}
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.hibernate.ddl-auto=update
spring.jpa.properties.hibernate.jdbc.time_zone=Asia/Almaty
spring.jackson.time-zone=Asia/Almaty

# Base64-encoded key (32+ raw bytes). Generate: [Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
jwt.secret=${JWT_SECRET:MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI=}
jwt.expiration=86400000

ai.service.url=${AI_SERVICE_URL:http://localhost:8000}

# --- Email (optional: omit spring.mail.host to skip sending; useful for local dev) ---
# SendGrid SMTP example:
# spring.mail.host=smtp.sendgrid.net
# spring.mail.port=587
# spring.mail.username=apikey
# spring.mail.password=YOUR_SENDGRID_API_KEY
# spring.mail.properties.mail.smtp.auth=true
# spring.mail.properties.mail.smtp.starttls.enable=true
#
# spring.mail.default-encoding=UTF-8

# From header (also used as Reply-To sender identity)
app.mail.from=Microgreens <noreply@yourdomain.com>

# Base URL of THIS API for email verification links (no trailing slash). Railway: https://… .up.railway.app
app.public-api-base-url=${APP_PUBLIC_API_BASE_URL:http://localhost:8080}

# Reset-password link base for email (no trailing slash).
app.password-reset-web-base=${APP_PASSWORD_RESET_WEB_BASE:http://localhost:3000}
